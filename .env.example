# Environment Configuration
# Copy this file to .env and update with your configuration

# Browser Configuration (chromium only, set HEADLESS to true for headless execution)
BROWSER_TYPE=chromium
HEADLESS=true

# Application URLs
BASE_URL=file:///D:/PlayWright_Typescript_Automation/BBD_POM_Automation/index.html

# Timeouts (in milliseconds)
IMPLICIT_WAIT=30000
EXPLICIT_WAIT=30000

# Test Results Path
TEST_RESULTS_PATH=./test-results

# Enable Screenshots
TAKE_SCREENSHOTS=true
